{
  "name": "nap",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:serv": "npm -w apps/nap-serv run dev",
    "dev:client": "npm -w apps/nap-client run dev",
    "dev": "npm run dev:serv & npm run dev:client",
    "build": "npm -w apps/nap-serv run build && npm -w apps/nap-client run build",
    "lint": "eslint .",
    "test": "npm -w apps/nap-serv test",
    "arch": "node scripts/arch/runAll.js",
    "arch:check": "node scripts/arch/runAll.js --check",
    "arch:ai": "node scripts/arch/aiInterpret.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/nap-serv/**/*.js": [
      "eslint --fix"
    ],
    "apps/nap-client/**/*.{js,jsx}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "eslint": "^9.34.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1"
  }
}
